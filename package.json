{
  "name": "chess-movegen",
  "version": "1.0.4",
  "description": "JavaScript chess move generator with strictly legal moves. x88 board representation. Integrated check/checkmate/stalemate detection. Tactical analysis. 5.6M NPS performance.",
  "main": "js/x88.js",
  "exports": {
    ".": {
      "types": "./js/x88.d.ts",
      "default": "./js/x88.js"
    },
    "./chessjs": {
      "types": "./js/chessjs-adapter.d.ts",
      "default": "./js/chessjs-adapter.js"
    },
    "./bitboard": "./js/bitboard.js"
  },
  "types": "./js/x88.d.ts",
  "files": [
    "js/x88.js",
    "js/x88.d.ts",
    "js/chessjs-adapter.js",
    "js/chessjs-adapter.d.ts",
    "js/bitboard.js",
    "js/magic-tables.js",
    "README.md",
    "README.es.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node tests/perft-test.js --quick",
    "test:full": "node tests/perft-test.js",
    "test:x88": "node tests/perft-test.js --generator x88",
    "test:bb": "node tests/perft-test.js --generator bb",
    "test:perf": "node tests/perft-test.js --quick --generator all",
    "test:adapter": "node tests/chessjs-adapter-test.js",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcarbonell/chess-movegen-js.git"
  },
  "keywords": [
    "chess",
    "chess-engine",
    "move-generation",
    "javascript",
    "x88",
    "bitboards",
    "uci",
    "perft",
    "chess-programming",
    "game-development",
    "legal-moves",
    "tactical-analysis"
  ],
  "author": "Mario Raúl Carbonell Martínez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mcarbonell/chess-movegen-js/issues"
  },
  "homepage": "https://mcarbonell.github.io/chess-movegen-js/",
  "engines": {
    "node": ">=14.0.0"
  },
  "directories": {
    "test": "tests"
  },
  "type": "commonjs",
  "devDependencies": {
    "@assemblyscript/loader": "^0.28.10",
    "assemblyscript": "^0.28.10",
    "chess.js": "^1.4.0"
  }
}
